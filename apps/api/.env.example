# Copy to .env (gitignored) and fill in real values. Load with: uv run --env-file .env <cmd>

# Database. Default is local SQLite; for Supabase use the Session pooler
# (IPv4, port 5432) connection string with the psycopg scheme:
#   postgresql+psycopg://postgres.<ref>:<password>@aws-<n>-<region>.pooler.supabase.com:5432/postgres
KBO_DATABASE_URL=sqlite:///./kbo_lineup_lab.db
